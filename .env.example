ANTHROPIC_API_KEY=your_deepseek_api_key

# Postgres for the workflow world (agent/agent.ts) and the dynamic schedule store.
WORKFLOW_POSTGRES_URL=postgres://user:pass@host:5432/dbname

# Discord channel (proactive delivery of scheduled reminders).
DISCORD_PUBLIC_KEY=...
DISCORD_APPLICATION_ID=...
DISCORD_BOT_TOKEN=...

# Jinshuju OAuth client, registered on account.jinshuju.net (/oauth/applications).
JINSHUJU_CLIENT_ID=...
JINSHUJU_CLIENT_SECRET=...
# Must exactly match the public /oauth/jinshuju/callback URL registered above.
JINSHUJU_REDIRECT_URI=http://localhost:3000/oauth/jinshuju/callback
JINSHUJU_ALLOWED_BILLING_ACCOUNT=im
# Optional overrides (defaults shown):
# JINSHUJU_OAUTH_BASE_URL=https://account.jinshuju.net
# JINSHUJU_API_BASE_URL=https://jinshuju.net
# JINSHUJU_OAUTH_SCOPES=public users
# Token store Postgres; falls back to WORKFLOW_POSTGRES_URL. Set this on
# hosts where the workflow world is managed (e.g. Vercel) and no
# WORKFLOW_POSTGRES_URL exists.
# JINSHUJU_TOKEN_POSTGRES_URL=postgres://user:pass@host:5432/dbname
