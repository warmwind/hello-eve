ANTHROPIC_API_KEY=your_deepseek_api_key

# Postgres for the workflow world (agent/agent.ts) and the dynamic schedule store.
WORKFLOW_POSTGRES_URL=postgres://user:pass@host:5432/dbname

# Discord channel (proactive delivery of scheduled reminders).
DISCORD_PUBLIC_KEY=...
DISCORD_APPLICATION_ID=...
DISCORD_BOT_TOKEN=...

# Okta OIDC test client and Eve route verifier. Use a SPA application with
# Authorization Code + PKCE and a Custom Authorization Server.
OKTA_ISSUER=https://dev-123456.okta.com/oauth2/default
OKTA_CLIENT_ID=...
OKTA_AUDIENCE=api://default
